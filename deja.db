BEGIN TRANSACTION;

-- 1. إنشاء الجدول بترتيب أعمدة منطقي
CREATE TABLE IF NOT EXISTS team_members (
    "id" INTEGER PRIMARY KEY AUTOINCREMENT,
    "الاسم_بالعربية" TEXT,
    "الاسم_بالانجليزية" TEXT,
    "تاريخ_الميلاد" TEXT,
    "رقم_الهاتف" TEXT,
    "البريد_الإلكتروني" TEXT,
    "مكان_السكن" TEXT,
    "الجامعة" TEXT,
    "التخصص" TEXT,
    "السنة_الدراسية" TEXT,
    "الخبرة_الرياضية" TEXT,
    "الفريق" TEXT,
    "الرتبة" TEXT,
    "ملاحظات" TEXT
);

